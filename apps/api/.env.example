# PostgreSQL (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/veo_services"

# SQL Server (Brilo legacy database)
SQLSERVER_HOST="your-sql-server-host"
SQLSERVER_PORT=1433
SQLSERVER_USERNAME="sa"
SQLSERVER_PASSWORD="your-password"
SQLSERVER_DATABASE="master"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="soporte.dev@arhedes.com.sv"
RESEND_TEST_TO_EMAIL="soporte.dev@arhedes.com.sv"

# PayPal
PAYPAL_API_KEY="your-paypal-client-id"
PAYPAL_KEY="your-paypal-secret"

# ImgBB
IMGBB_API_KEY="your-imgbb-api-key"

# Cron
CRON_SECRET="your-cron-secret"

# Better Auth
BETTER_AUTH_SECRET="generate-a-32-char-secret-here"
BETTER_AUTH_URL="http://localhost:4000"
TRUSTED_ORIGINS="http://localhost:3000"

# General
PORT=4000
NODE_ENV=development

# Max JSON/urlencoded body size (e.g. base64 images); default in code is 15mb if unset
BODY_SIZE_LIMIT=15mb

# Billboard/shop cache TTL in milliseconds; default is 300000 (5 minutes)
BILLBOARD_CACHE_TTL_MS=300000

# Redis (optional – enables persistent image caching; falls back to in-memory if unset)
REDIS_URL="redis://localhost:6379"

# Billboard image Redis TTL in seconds; default is 86400 (24 hours)
BILLBOARD_IMAGE_REDIS_TTL_S=86400
