generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String           @id
  publicId          String           @unique @default(uuid()) @map("public_id")
  firstName         String           @map("first_name")
  lastName          String?          @map("last_name")
  email             String           @unique
  role              Role             @default(USER)
  subRoles          SubRole[]        @default([]) @map("sub_roles")
  disabled          Boolean          @default(false)
  lastLoginAt       DateTime?        @map("last_login_at")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  emailVerified     Boolean          @default(false)
  image             String?
  accounts          Account[]
  sessions          Session[]
  s3Images          S3Image[]
  teamMember        TeamMember?      @relation("TeamMemberUser")
  teamMembersAsBoss TeamMember[]     @relation("TeamMemberDirectBoss")
  absences          Absence[]
  notifications     Notification[]
  metrics           UserMetrics?
  metricsDays       UserMetricsDay[]

  @@map("users")
}

enum ContractType {
  FULL_TIME
  TEMPORAL
  FREELANCE
  PART_TIME
  INTERNSHIP
  PROFESSIONAL_SERVICES
}

enum TeamMemberStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

model TeamMember {
  id                           String              @id @default(uuid())
  userId                       String              @unique @map("user_id")
  firstName                    String              @map("first_name")
  lastName                     String?             @map("last_name")
  secondLastName               String?             @map("second_last_name")
  fullName                     String              @map("full_name")
  dui                          String?             @map("dui")
  inss                         String?             @map("inss")
  afpNumber                    String?             @map("afp_number")
  afpEntity                    String?             @map("afp_entity")
  bankName                     String?             @map("bank_name")
  bankAccount                  String?             @map("bank_account")
  bornDate                     DateTime?           @map("born_date")
  startDate                    DateTime?           @map("start_date")
  endDate                      DateTime?           @map("end_date")
  contractType                 ContractType        @default(FULL_TIME)
  status                       TeamMemberStatus    @default(ACTIVE)
  emergencyContactName         String?             @map("emergency_contact_name")
  emergencyContactPhone        String?             @map("emergency_contact_phone")
  emergencyContactRelationship String?             @map("emergency_contact_relationship")
  directBoss                   User?               @relation("TeamMemberDirectBoss", fields: [directBossId], references: [id])
  directBossId                 String?             @map("direct_boss_id")
  businessEmail                String              @unique @map("business_email")
  position                     String
  salary                       Float
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  user                         User                @relation("TeamMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  teamMemberComments           TeamMemberComment[]

  @@map("team_members")
}

model TeamMemberComment {
  id           String     @id @default(uuid())
  teamMemberId String     @map("team_member_id")
  comment      String
  showToUser   Boolean    @default(false) @map("show_to_user")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@map("team_member_comments")
}

model Absence {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  fromDate  DateTime       @map("from_date")
  toDate    DateTime       @map("to_date")
  reason    String
  status    AbsenceStatus  @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  images    AbsenceImage[]

  @@index([userId])
  @@map("absences")
}

model AbsenceImage {
  id        String   @id @default(uuid())
  absenceId String   @map("absence_id")
  url       String
  createdAt DateTime @default(now())
  absence   Absence  @relation(fields: [absenceId], references: [id], onDelete: Cascade)

  @@index([absenceId])
  @@map("absence_images")
}

model Notification {
  id          String                 @id @default(uuid())
  userId      String                 @map("user_id")
  status      UserNotificationStatus @default(PENDING)
  description String
  priority    NotificationPriority   @default(MEDIUM)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("notifications")
}

model UserMetrics {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  lastTickAt DateTime @default(now()) @map("last_tick_at")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_metrics")
}

model UserMetricsDay {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  activeMs  Int      @default(0) @map("active_ms")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("user_metrics_days")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model NotifiedContract {
  id                     String             @id @default(uuid())
  contractSourceId       Int
  contractDetailSourceId Int
  contractNumber         String
  status                 NotificationStatus @default(PENDING)
  errorMessage           String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@map("notified_contract")
}

model Customer {
  id        String     @id @default(uuid())
  name      String?
  email     String     @unique
  phone     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  @@map("customers")
}

model Purchase {
  id              String         @id @default(uuid())
  customerId      String
  status          PurchaseStatus @default(PENDING)
  paypalOrderId   String?
  paypalCaptureId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           PurchaseItem[]
  customer        Customer       @relation(fields: [customerId], references: [id])

  @@map("purchases")
}

model PurchaseItem {
  id                 String            @id @default(uuid())
  purchaseId         String
  billboardId        Int?
  billboardCode      String?
  reference          String?
  departmentName     String?
  cityName           String?
  address            String?
  price              Float?
  from               DateTime
  to                 DateTime
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  digitalBillboardId String?
  spotCount          Int?
  digitalBillboard   DigitalBillboard? @relation(fields: [digitalBillboardId], references: [id])
  purchase           Purchase          @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([billboardId, from, to])
  @@index([digitalBillboardId, from, to])
  @@map("purchase_items")
}

model Image {
  id                String             @id @default(uuid())
  completeUrl       String
  thumbnailUrl      String
  mediumUrl         String
  deleteUrl         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  digitalBillboards DigitalBillboard[]

  @@map("images")
}

model DigitalBillboardUsage {
  id                  String           @id @default(uuid())
  digitalBillboardId  String
  timestamp           DateTime
  duration            Int
  campaignName        String?
  campaignDescription String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  digitalBillboard    DigitalBillboard @relation(fields: [digitalBillboardId], references: [id])

  @@index([digitalBillboardId, timestamp])
  @@map("digital_billboard_usages")
}

model DigitalBillboard {
  id                     String                  @id @default(uuid())
  code                   String                  @unique
  name                   String
  address                String
  latitude               Float
  longitude              Float
  price                  Float
  imageId                String?
  maxSpots               Int                     @default(900)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  departmentId           Int?                    @map("department_id")
  departmentName         String?                 @map("department_name")
  digitalBillboardUsages DigitalBillboardUsage[]
  image                  Image?                  @relation(fields: [imageId], references: [id])
  purchaseItems          PurchaseItem[]

  @@map("digital_billboards")
}

enum Role {
  ADMIN
  USER
  LIMITED
}

enum SubRole {
  HR
  USERS_MANAGEMENT
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserNotificationStatus {
  PENDING
  VIEWED
  DELETED
}

enum NotificationPriority {
  HIGH
  MEDIUM
  LOW
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}

enum S3ImageType {
  STATIC_BILLBOARD_MONTHLY
  STATIC_BILLBOARD_MAINTENANCE
  STATIC_BILLBOARD_INSTALLATION
}

model S3Image {
  id                    String                @id @default(uuid())
  url                   String
  deleteUrl             String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  uploadedUserId        String
  uploadedUser          User                  @relation(fields: [uploadedUserId], references: [id])
  tags                  String[]              @default([])
  staticBillboardCodeId String?
  staticBillboardCode   StaticBillboardCodes? @relation(fields: [staticBillboardCodeId], references: [id])
  type                  S3ImageType

  @@map("s3_images")
}

model StaticBillboardCodes {
  id        String    @id @default(uuid())
  code      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  s3Images  S3Image[]

  @@map("static_billboard_codes")
}
