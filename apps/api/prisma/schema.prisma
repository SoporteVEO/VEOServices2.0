generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  publicId      String    @unique @default(uuid()) @map("public_id")
  firstName     String    @map("first_name")
  lastName      String?   @map("last_name")
  email         String    @unique
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified Boolean   @default(false)
  image         String?
  accounts      Account[]
  sessions      Session[]
  s3Images      S3Image[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model NotifiedContract {
  id                     String             @id @default(uuid())
  contractSourceId       Int
  contractDetailSourceId Int
  contractNumber         String
  status                 NotificationStatus @default(PENDING)
  errorMessage           String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@map("notified_contract")
}

model Customer {
  id        String     @id @default(uuid())
  name      String?
  email     String     @unique
  phone     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  @@map("customers")
}

model Purchase {
  id              String         @id @default(uuid())
  customerId      String
  status          PurchaseStatus @default(PENDING)
  paypalOrderId   String?
  paypalCaptureId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           PurchaseItem[]
  customer        Customer       @relation(fields: [customerId], references: [id])

  @@map("purchases")
}

model PurchaseItem {
  id                 String            @id @default(uuid())
  purchaseId         String
  billboardId        Int?
  billboardCode      String?
  reference          String?
  departmentName     String?
  cityName           String?
  address            String?
  price              Float?
  from               DateTime
  to                 DateTime
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  digitalBillboardId String?
  spotCount          Int?
  digitalBillboard   DigitalBillboard? @relation(fields: [digitalBillboardId], references: [id])
  purchase           Purchase          @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([billboardId, from, to])
  @@index([digitalBillboardId, from, to])
  @@map("purchase_items")
}

model Image {
  id                String             @id @default(uuid())
  completeUrl       String
  thumbnailUrl      String
  mediumUrl         String
  deleteUrl         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  digitalBillboards DigitalBillboard[]

  @@map("images")
}

model DigitalBillboardUsage {
  id                  String           @id @default(uuid())
  digitalBillboardId  String
  timestamp           DateTime
  duration            Int
  campaignName        String?
  campaignDescription String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  digitalBillboard    DigitalBillboard @relation(fields: [digitalBillboardId], references: [id])

  @@index([digitalBillboardId, timestamp])
  @@map("digital_billboard_usages")
}

model DigitalBillboard {
  id                     String                  @id @default(uuid())
  code                   String                  @unique
  name                   String
  address                String
  latitude               Float
  longitude              Float
  price                  Float
  imageId                String?
  maxSpots               Int                     @default(900)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  departmentId           Int?                    @map("department_id")
  departmentName         String?                 @map("department_name")
  digitalBillboardUsages DigitalBillboardUsage[]
  image                  Image?                  @relation(fields: [imageId], references: [id])
  purchaseItems          PurchaseItem[]

  @@map("digital_billboards")
}

enum Role {
  ADMIN
  USER
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}

enum S3ImageType {
  STATIC_BILLBOARD_MONTHLY
}

model S3Image {
  id                    String                @id @default(uuid())
  url                   String
  deleteUrl             String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  uploadedUserId        String
  uploadedUser          User                  @relation(fields: [uploadedUserId], references: [id])
  tags                  String[]              @default([])
  staticBillboardCodeId String?
  staticBillboardCode   StaticBillboardCodes? @relation(fields: [staticBillboardCodeId], references: [id])
  type                  S3ImageType

  @@map("s3_images")
}

model StaticBillboardCodes {
  id        String    @id @default(uuid())
  code      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  s3Images  S3Image[]

  @@map("static_billboard_codes")
}
